MEMORY_DEPLOY_PROFILE=local
MEMORY_DATABASE_URL=postgresql+asyncpg://memory:memory@127.0.0.1:54329/memory
MEMORY_AUTO_CREATE_SCHEMA=true
MEMORY_HOST=127.0.0.1
MEMORY_PORT=7788
MEMORY_SERVICE_TOKEN=local-dev-token
MEMORY_POLICY_MODE=active_context

# Compatibility alias for MEMORY_CAPTURE_MODE. When set, this wins.
# MEMORY_AUTO_MEMORY_MODE=retrieve_only
MEMORY_CAPTURE_MODE=retrieve_only
MEMORY_CAPTURE_EXTERNAL_AI_ENABLED=false
MEMORY_CAPTURE_EXTRACTOR_PROVIDER=rule_based
MEMORY_CAPTURE_EXTRACTOR_MODEL=gpt-4.1-mini
MEMORY_CAPTURE_DEFAULT_CONSOLIDATE=true
MEMORY_AUTO_APPLY_SAFE_ENABLED=false
MEMORY_MAX_CAPTURE_TEXT_CHARS=20000
MEMORY_MAX_PENDING_CAPTURES_PER_MEMORY_SCOPE=5000
MEMORY_MAX_PENDING_SUGGESTIONS_PER_MEMORY_SCOPE=500
MEMORY_PRODUCT_PLAN_TIER=free
MEMORY_PLAN_MEDIA_ANALYSIS_SECONDS_PER_MONTH=36000

MEMORY_ASSET_STORAGE_DIR=~/.memo-stack/assets
MEMORY_MAX_ASSET_UPLOAD_BYTES=26214400
MEMORY_EXTRACTION_ENABLED=true
# standard_local is lightweight. Use standard_docling after installing memo-stack[docling].
MEMORY_EXTRACTION_DEFAULT_PROFILE=standard_local
MEMORY_EXTRACTION_EXTERNAL_AI_ENABLED=false
MEMORY_EXTRACTION_MAX_BYTES=26214400
MEMORY_EXTRACTION_MAX_PAGES=100
MEMORY_EXTRACTION_MAX_MEDIA_SECONDS=600
MEMORY_EXTRACTION_MAX_OUTPUT_CHARS=500000
MEMORY_EXTRACTION_MAX_TABLES=100
MEMORY_EXTRACTION_EXECUTION_LEASE_SECONDS=900
MEMORY_EXTRACTION_PARSER_TIMEOUT_SECONDS=300
MEMORY_EXTRACTION_SUBPROCESS_TIMEOUT_SECONDS=60
MEMORY_EXTRACTION_MAX_IMAGE_PIXELS=50000000
MEMORY_EXTRACTION_OCR_ENABLED=true
# Used by standard_vision and standard_full when external AI egress is enabled.
MEMORY_EXTRACTION_VISION_MODEL=gpt-4.1-mini
MEMORY_EXTRACTION_VISION_DETAIL=high
# Used by standard_asr and standard_full after installing memo-stack[asr].
MEMORY_EXTRACTION_ASR_MODEL=base
MEMORY_EXTRACTION_ASR_DEVICE=auto
MEMORY_EXTRACTION_ASR_COMPUTE_TYPE=default

MEMORY_QDRANT_ENABLED=false
MEMORY_QDRANT_URL=http://127.0.0.1:6333
MEMORY_QDRANT_COLLECTION=memory_chunks_v1

MEMORY_EMBEDDINGS_ENABLED=false
MEMORY_EMBEDDINGS_PROVIDER=noop
MEMORY_EMBEDDINGS_MODEL=text-embedding-3-small
MEMORY_EMBEDDINGS_DIMENSIONS=1536
MEMORY_OPENAI_API_KEY=
# Graphiti currently reads the standard OpenAI env var from its runtime.
# For full local mode, set both variables to the same secret in your shell or
# in a local ignored env file.
OPENAI_API_KEY=

MEMORY_GRAPHITI_ENABLED=false
MEMORY_GRAPHITI_NEO4J_URI=bolt://127.0.0.1:7687
MEMORY_GRAPHITI_NEO4J_USER=neo4j
MEMORY_GRAPHITI_NEO4J_PASSWORD=memorygraph
MEMORY_GRAPHITI_BUILD_INDICES=false

MEMORY_LEGACY_CLIENT_ENABLED=false
MEMORY_DEFAULT_SPACE_SLUG=default
MEMORY_DEFAULT_MEMORY_SCOPE_EXTERNAL_REF=default
MEMORY_MAX_CONTEXT_TOKENS=1800
MEMORY_MAX_CONTEXT_CHARS=18000
MEMORY_MAX_MEMORY_CANDIDATES=2000
MEMORY_MAX_MEMORY_RESULTS=32
MEMORY_PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
MEMORY_PROVIDER_CIRCUIT_RESET_AFTER_SECONDS=60
