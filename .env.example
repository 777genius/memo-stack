MEMORY_DEPLOY_PROFILE=local
MEMORY_DATABASE_URL=postgresql+asyncpg://memory:memory@127.0.0.1:54329/memory
MEMORY_AUTO_CREATE_SCHEMA=true
MEMORY_HOST=127.0.0.1
MEMORY_PORT=7788
MEMORY_SERVICE_TOKEN=local-dev-token
MEMORY_POLICY_MODE=active_context

MEMORY_QDRANT_ENABLED=false
MEMORY_QDRANT_URL=http://127.0.0.1:6333
MEMORY_QDRANT_COLLECTION=memory_chunks_v1

MEMORY_EMBEDDINGS_ENABLED=false
MEMORY_EMBEDDINGS_PROVIDER=noop
MEMORY_EMBEDDINGS_MODEL=text-embedding-3-small
MEMORY_EMBEDDINGS_DIMENSIONS=1536
MEMORY_OPENAI_API_KEY=
# Graphiti currently reads the standard OpenAI env var from its runtime.
# For full local mode, set both variables to the same secret in your shell or
# in a local ignored env file.
OPENAI_API_KEY=

MEMORY_GRAPHITI_ENABLED=false
MEMORY_GRAPHITI_NEO4J_URI=bolt://127.0.0.1:7687
MEMORY_GRAPHITI_NEO4J_USER=neo4j
MEMORY_GRAPHITI_NEO4J_PASSWORD=memorygraph
MEMORY_GRAPHITI_BUILD_INDICES=false

MEMORY_LEGACY_HACKINTERVIEW_ENABLED=true
MEMORY_DEFAULT_SPACE_SLUG=hackinterview
MEMORY_DEFAULT_PROFILE_EXTERNAL_REF=default
MEMORY_MAX_CONTEXT_TOKENS=1800
MEMORY_MAX_CONTEXT_CHARS=18000
MEMORY_MAX_MEMORY_CANDIDATES=2000
MEMORY_MAX_MEMORY_RESULTS=32
MEMORY_PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
MEMORY_PROVIDER_CIRCUIT_RESET_AFTER_SECONDS=60
