# Copy this file to .env.selfhost and replace every change-me value before use.

MEMORY_SERVICE_TOKEN=change-me-generate-with-openssl-rand-hex-32
MEMORY_POSTGRES_PASSWORD=change-me-generate-with-openssl-rand-hex-32
MEMORY_SERVER_PORT=7788

MEMORY_POLICY_MODE=suggestions
MEMORY_CAPTURE_MODE=suggest
MEMORY_CAPTURE_EXTERNAL_AI_ENABLED=false
MEMORY_CAPTURE_EXTRACTOR_PROVIDER=rule_based
MEMORY_CAPTURE_EXTRACTOR_MODEL=gpt-4.1-mini
MEMORY_CAPTURE_DEFAULT_CONSOLIDATE=true

MEMORY_DEFAULT_SPACE_SLUG=team
MEMORY_DEFAULT_MEMORY_SCOPE_EXTERNAL_REF=default
MEMORY_LEGACY_CLIENT_ENABLED=false
MEMORY_PRODUCT_PLAN_TIER=free
MEMORY_PLAN_MEDIA_ANALYSIS_SECONDS_PER_MONTH=36000

MEMORY_MAX_ASSET_UPLOAD_BYTES=26214400
MEMORY_EXTRACTION_ENABLED=true
MEMORY_EXTRACTION_MAX_BYTES=26214400
MEMORY_EXTRACTION_MAX_PAGES=100
MEMORY_EXTRACTION_MAX_MEDIA_SECONDS=600
MEMORY_EXTRACTION_MAX_OUTPUT_CHARS=500000
MEMORY_EXTRACTION_MAX_TABLES=100
MEMORY_EXTRACTION_EXECUTION_LEASE_SECONDS=900
MEMORY_EXTRACTION_PARSER_TIMEOUT_SECONDS=300
MEMORY_EXTRACTION_SUBPROCESS_TIMEOUT_SECONDS=60
MEMORY_EXTRACTION_MAX_IMAGE_PIXELS=50000000
MEMORY_EXTRACTION_OCR_ENABLED=true
MEMORY_EXTRACTION_EXTERNAL_AI_ENABLED=false
MEMORY_EXTRACTION_DEFAULT_PROFILE=standard_local

MEMORY_QDRANT_ENABLED=false
MEMORY_QDRANT_COLLECTION=memo_stack_chunks_v1

MEMORY_EMBEDDINGS_ENABLED=false
MEMORY_EMBEDDINGS_PROVIDER=noop
MEMORY_EMBEDDINGS_MODEL=text-embedding-3-small
MEMORY_EMBEDDINGS_DIMENSIONS=1536
MEMORY_OPENAI_API_KEY=
OPENAI_API_KEY=

MEMORY_GRAPHITI_ENABLED=false
MEMORY_GRAPHITI_NEO4J_USER=neo4j
MEMORY_GRAPHITI_NEO4J_PASSWORD=change-me-only-needed-when-graphiti-enabled
MEMORY_GRAPHITI_BUILD_INDICES=false

MEMORY_PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
MEMORY_PROVIDER_CIRCUIT_RESET_AFTER_SECONDS=60
