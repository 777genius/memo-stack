{
  "name": "infinity-context-obsidian-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Thin Obsidian plugin for controlling the Infinity Context Obsidian connector.",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "NODE_ENV=development node esbuild.config.mjs --watch",
    "test:e2e:obsidian": "node test/run-obsidian-e2e.cjs",
    "test:e2e:obsidian:run": "npm run build && wdio run ./wdio.conf.mts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.2",
    "@wdio/cli": "^9.27.2",
    "@wdio/globals": "^9.27.2",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "@wdio/spec-reporter": "^9.27.2",
    "esbuild": "^0.28.0",
    "expect-webdriverio": "^5.6.7",
    "obsidian": "^1.13.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "webdriverio": "^9.27.2",
    "wdio-obsidian-reporter": "^3.1.0",
    "wdio-obsidian-service": "^3.1.0"
  }
}
