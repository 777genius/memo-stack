{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noImplicitAny": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2018",
    "types": [
      "node",
      "@wdio/globals/types",
      "@wdio/mocha-framework",
      "wdio-obsidian-service"
    ]
  },
  "include": ["main.ts", "wdio.conf.mts", "test/**/*.ts"]
}
