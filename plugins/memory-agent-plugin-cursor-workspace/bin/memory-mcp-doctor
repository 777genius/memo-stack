#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
plugin_root="$(cd "${script_dir}/.." && pwd)"
repo_root="$(cd "${plugin_root}/../.." && pwd)"

python_bin="${repo_root}/.venv/bin/python"
if [ ! -x "${python_bin}" ]; then
  if command -v python3 >/dev/null 2>&1; then
    python_bin="$(command -v python3)"
  elif command -v python >/dev/null 2>&1; then
    python_bin="$(command -v python)"
  else
    printf '%s\n' "error: Python not found. Create ${repo_root}/.venv or install python3."
    exit 127
  fi
fi

memory_pythonpath="${repo_root}/packages/memory_core:${repo_root}/packages/memory_server:${repo_root}/packages/memory_adapters:${repo_root}/packages/memory_sdk:${repo_root}/packages/memory_mcp"
if [ -n "${PYTHONPATH:-}" ]; then
  export PYTHONPATH="${memory_pythonpath}:${PYTHONPATH}"
else
  export PYTHONPATH="${memory_pythonpath}"
fi

"${python_bin}" - <<'PY'
from __future__ import annotations

import importlib
import http.client
import json
import os
import sys
import urllib.error
import urllib.parse
import urllib.request


def fail(message: str, code: int = 1) -> None:
    print(f"error: {message}")
    raise SystemExit(code)


def ok(message: str) -> None:
    print(f"ok: {message}")


def safe_url(url: str) -> str:
    try:
        parsed = urllib.parse.urlsplit(url.strip())
    except ValueError:
        return "<invalid-url>"

    try:
        host = parsed.hostname or ""
    except ValueError:
        host = ""
    if ":" in host and not host.startswith("["):
        host = f"[{host}]"
    try:
        port = parsed.port
    except ValueError:
        port = None
    if port is not None:
        host = f"{host}:{port}"
    if parsed.username or parsed.password:
        host = f"<redacted>@{host}" if host else "<redacted>"

    redacted = urllib.parse.urlunsplit(
        (
            parsed.scheme,
            host,
            parsed.path,
            "",
            "",
        )
    )
    if parsed.query:
        redacted = f"{redacted}?<redacted>"
    if parsed.fragment:
        redacted = f"{redacted}#<redacted>"
    return redacted


def redact_text(value: object, *, raw_url: str, token: str) -> str:
    text = str(value)
    text = text.replace(raw_url, safe_url(raw_url))
    if token:
        text = text.replace(token, "<redacted>")
    try:
        parsed = urllib.parse.urlsplit(raw_url)
    except ValueError:
        return text
    try:
        parsed_port = parsed.port
    except ValueError:
        parsed_port = None
        if ":" in parsed.netloc:
            invalid_port = parsed.netloc.rsplit(":", 1)[-1]
            if invalid_port:
                text = text.replace(invalid_port, "<redacted>")
    for part in (
        parsed.username,
        parsed.password,
        str(parsed_port) if parsed_port is not None else "",
        parsed.query,
        parsed.fragment,
    ):
        if part:
            text = text.replace(part, "<redacted>")
    return text


def request_json(url: str, token: str) -> dict[str, object]:
    display_url = safe_url(url)
    try:
        request = urllib.request.Request(
            url,
            headers={
                "Authorization": f"Bearer {token}",
                "Accept": "application/json",
            },
        )
    except ValueError as exc:
        fail(f"{display_url} is invalid: {redact_text(exc, raw_url=url, token=token)}")
    try:
        with urllib.request.urlopen(request, timeout=5) as response:
            body = response.read().decode("utf-8")
    except ValueError as exc:
        fail(f"{display_url} is invalid: {redact_text(exc, raw_url=url, token=token)}")
    except http.client.InvalidURL as exc:
        fail(f"{display_url} is invalid: {redact_text(exc, raw_url=url, token=token)}")
    except urllib.error.HTTPError as exc:
        fail(f"{display_url} returned HTTP {exc.code}")
    except urllib.error.URLError as exc:
        reason = getattr(exc, "reason", exc)
        fail(f"{display_url} is unavailable: {redact_text(reason, raw_url=url, token=token)}")

    try:
        parsed = json.loads(body)
    except json.JSONDecodeError:
        fail(f"{display_url} returned invalid JSON")
    if not isinstance(parsed, dict):
        fail(f"{display_url} returned a non-object JSON payload")
    return parsed


ok(f"python {sys.executable}")
try:
    importlib.import_module("memory_mcp")
    importlib.import_module("memory_mcp.server")
except Exception as exc:
    fail(f"cannot import memory_mcp: {exc}")
ok("memory_mcp import")

api_url = os.getenv("MEMORY_MCP_API_URL", "").rstrip("/")
if not api_url:
    fail("MEMORY_MCP_API_URL is not set")
ok(f"api url {safe_url(api_url)}")

token = os.getenv("MEMORY_MCP_AUTH_TOKEN") or os.getenv("MEMORY_SERVICE_TOKEN") or ""
if not token:
    fail("MEMORY_MCP_AUTH_TOKEN or MEMORY_SERVICE_TOKEN is not set")
ok("auth token configured")

health = request_json(f"{api_url}/v1/health", token)
if health.get("ok") is not True and health.get("status") != "ok":
    fail("/v1/health did not report ok=true or status=ok")
ok("/v1/health")

capabilities = request_json(f"{api_url}/v1/capabilities", token)
if "adapters" not in capabilities:
    fail("/v1/capabilities missing adapters")
ok("/v1/capabilities")
ok("Memo Stack MCP plugin is ready")
PY
